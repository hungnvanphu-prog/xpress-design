{
  "kind": "collectionType",
  "collectionName": "articles",
  "info": {
    "singularName": "article",
    "pluralName": "articles",
    "displayName": "Article",
    "description": "Góc nhìn / Blog"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true,
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "excerpt": {
      "type": "text",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "content": {
      "type": "richtext",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "thumbnail": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"],
      "pluginOptions": { "i18n": { "localized": false } }
    },
    "tags": {
      "type": "json",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::category.category",
      "inversedBy": "articles"
    },
    "seo_title": {
      "type": "string",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "seo_description": {
      "type": "text",
      "pluginOptions": { "i18n": { "localized": true } }
    }
  }
}
