{
  "kind": "collectionType",
  "collectionName": "articles",
  "info": {
    "singularName": "article",
    "pluralName": "articles",
    "displayName": "Article",
    "description": "Góc nhìn / Blog"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true,
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "excerpt": {
      "type": "text",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "lead": {
      "type": "text",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "reading_time_minutes": {
      "type": "integer",
      "min": 1,
      "pluginOptions": { "i18n": { "localized": false } }
    },
    "author_display_name": {
      "type": "string",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "author_role": {
      "type": "string",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "author_bio": {
      "type": "text",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "author_avatar": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"],
      "pluginOptions": { "i18n": { "localized": false } }
    },
    "hero_image_url": {
      "type": "string",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "content": {
      "type": "richtext",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "thumbnail": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"],
      "pluginOptions": { "i18n": { "localized": false } }
    },
    "tags": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::tag.tag",
      "inversedBy": "articles"
    },
    "tag_multiselect": {
      "type": "customField",
      "customField": "plugin::article-tag-picker.tag-multiselect",
      "private": true,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::category.category",
      "inversedBy": "articles"
    },
    "seo_title": {
      "type": "string",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "seo_description": {
      "type": "text",
      "pluginOptions": { "i18n": { "localized": true } }
    }
  }
}
