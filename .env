# ===== Postgres (shared) =====
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin
POSTGRES_DB=postgres

# ===== NestJS backend =====
DATABASE_URL=postgresql://admin:admin@postgres:5432/app_db
JWT_SECRET=supersecret-change-me
JWT_EXPIRES_IN=7d
PORT=4000
STRAPI_URL=http://cms:1337
STRAPI_TOKEN=

# ===== Strapi CMS =====
HOST=0.0.0.0
CMS_PORT=1337
APP_KEYS=abc,def
API_TOKEN_SALT=xyz
ADMIN_JWT_SECRET=secret
TRANSFER_TOKEN_SALT=salt-change-me
# JWT_SECRET dùng chung với backend (hoặc tách nếu muốn)
DATABASE_CLIENT=postgres
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=cms_db
DATABASE_USERNAME=admin
DATABASE_PASSWORD=admin
DATABASE_SSL=false

# Seed admin Strapi (lần đầu chạy)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=Admin@12345
SEED_ADMIN_FIRSTNAME=Super
SEED_ADMIN_LASTNAME=Admin