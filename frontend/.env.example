# URL mà browser (client-side) dùng để gọi API
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_CMS_URL=http://localhost:1337

# Production (build Docker + nginx domain + subdomain CMS), ví dụ:
# NEXT_PUBLIC_API_URL=https://tenmien.com/api
# NEXT_PUBLIC_CMS_URL=https://cms.tenmien.com

# URL mà Next.js (server-side, bên trong docker) dùng
# → trỏ tới service name trong compose
INTERNAL_API_URL=http://backend:4000/api
INTERNAL_CMS_URL=http://cms:1337
